{
  "name": "@engrams/core",
  "version": "0.1.0",
  "description": "Schema, types, and confidence engine for Engrams",
  "license": "MIT",
  "author": "Sunrise Labs <hello@sunrise-labs.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sunrise-Labs-Dot-AI/engrams.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./llm": {
      "import": "./dist/llm.js",
      "types": "./dist/llm.d.ts"
    },
    "./llm-config": {
      "import": "./dist/llm-config.js",
      "types": "./dist/llm-config.d.ts"
    },
    "./llm-utils": {
      "import": "./dist/llm-utils.js",
      "types": "./dist/llm-utils.d.ts"
    },
    "./llm-validation": {
      "import": "./dist/llm-validation.js",
      "types": "./dist/llm-validation.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto.js",
      "types": "./dist/crypto.d.ts"
    },
    "./pii": {
      "import": "./dist/pii.js",
      "types": "./dist/pii.d.ts"
    },
    "./credentials": {
      "import": "./dist/credentials.js",
      "types": "./dist/credentials.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "eval": "vitest run --config src/__evals__/vitest.eval.config.ts",
    "eval:search": "vitest run --config src/__evals__/vitest.eval.config.ts search.eval",
    "eval:dedup": "vitest run --config src/__evals__/vitest.eval.config.ts dedup.eval",
    "eval:entity": "vitest run --config src/__evals__/vitest.eval.config.ts entity.eval",
    "eval:e2e": "vitest run --config src/__evals__/vitest.eval.config.ts e2e.eval",
    "eval:graph": "vitest run --config src/__evals__/vitest.eval.config.ts graph.eval"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.2",
    "@libsql/client": "^0.17.2",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.3",
    "vitest": "^4.1.1"
  }
}
